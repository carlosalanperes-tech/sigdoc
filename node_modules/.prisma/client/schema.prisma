generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model audit_logs {
  id             BigInt       @id @default(autoincrement())
  institution_id BigInt
  user_id        BigInt?
  action         String       @db.VarChar(100)
  entity_type    String?      @db.VarChar(100)
  entity_id      BigInt?
  description    String?      @db.Text
  ip_address     String?      @db.VarChar(50)
  user_agent     String?      @db.Text
  created_at     DateTime?    @default(now()) @db.DateTime(0)
  institutions   institutions @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "audit_logs_ibfk_1")
  users          users?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "audit_logs_ibfk_2")

  @@index([institution_id], map: "institution_id")
  @@index([user_id], map: "user_id")
}

model contact_group_members {
  id             BigInt         @id @default(autoincrement())
  group_id       BigInt
  contact_id     BigInt
  contact_groups contact_groups @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "contact_group_members_ibfk_1")
  contacts       contacts       @relation(fields: [contact_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "contact_group_members_ibfk_2")

  @@unique([group_id, contact_id], map: "unique_group_contact")
  @@index([contact_id], map: "contact_id")
}

model contact_groups {
  id                    BigInt                  @id @default(autoincrement())
  institution_id        BigInt
  name                  String                  @db.VarChar(255)
  description           String?                 @db.Text
  created_at            DateTime?               @default(now()) @db.DateTime(0)
  contact_group_members contact_group_members[]
  institutions          institutions            @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "contact_groups_ibfk_1")

  @@index([institution_id], map: "institution_id")
}

model contacts {
  id                    BigInt                  @id @default(autoincrement())
  institution_id        BigInt
  name                  String                  @db.VarChar(255)
  organization          String?                 @db.VarChar(255)
  position              String?                 @db.VarChar(150)
  email                 String?                 @db.VarChar(150)
  phone                 String?                 @db.VarChar(30)
  whatsapp              String?                 @db.VarChar(30)
  address               String?                 @db.VarChar(255)
  notes                 String?                 @db.Text
  is_active             Boolean?                @default(true)
  created_at            DateTime?               @default(now()) @db.DateTime(0)
  updated_at            DateTime?               @default(now()) @db.DateTime(0)
  contact_group_members contact_group_members[]
  institutions          institutions            @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "contacts_ibfk_1")

  @@index([institution_id], map: "institution_id")
}

model document_approvals {
  id                                           BigInt                     @id @default(autoincrement())
  document_id                                  BigInt
  requested_by                                 BigInt
  approved_by                                  BigInt?
  status                                       document_approvals_status? @default(pending)
  comments                                     String?                    @db.Text
  requested_at                                 DateTime?                  @default(now()) @db.DateTime(0)
  decided_at                                   DateTime?                  @db.DateTime(0)
  documents                                    documents                  @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_approvals_ibfk_1")
  users_document_approvals_requested_byTousers users                      @relation("document_approvals_requested_byTousers", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_approvals_ibfk_2")
  users_document_approvals_approved_byTousers  users?                     @relation("document_approvals_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_approvals_ibfk_3")

  @@index([approved_by], map: "approved_by")
  @@index([document_id], map: "document_id")
  @@index([requested_by], map: "requested_by")
}

model document_attachments {
  id          BigInt    @id @default(autoincrement())
  document_id BigInt
  file_name   String    @db.VarChar(255)
  file_url    String    @db.VarChar(500)
  file_type   String?   @db.VarChar(100)
  file_size   BigInt?
  uploaded_by BigInt
  created_at  DateTime? @default(now()) @db.DateTime(0)
  documents   documents @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_attachments_ibfk_1")
  users       users     @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_attachments_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([uploaded_by], map: "uploaded_by")
}

model document_sends {
  id              BigInt                 @id @default(autoincrement())
  document_id     BigInt
  sent_by         BigInt
  channel         document_sends_channel
  recipient_name  String?                @db.VarChar(255)
  recipient_email String?                @db.VarChar(150)
  recipient_phone String?                @db.VarChar(30)
  subject         String?                @db.VarChar(255)
  message         String?                @db.Text
  sent_at         DateTime?              @default(now()) @db.DateTime(0)
  status          document_sends_status? @default(sent)
  error_message   String?                @db.Text
  documents       documents              @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_sends_ibfk_1")
  users           users                  @relation(fields: [sent_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_sends_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([sent_by], map: "sent_by")
}

model document_sequences {
  id               BigInt         @id @default(autoincrement())
  institution_id   BigInt
  document_type_id BigInt
  year             Int
  current_number   Int?           @default(0)
  institutions     institutions   @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_sequences_ibfk_1")
  document_types   document_types @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_sequences_ibfk_2")

  @@unique([institution_id, document_type_id, year], map: "unique_sequence")
  @@index([document_type_id], map: "document_type_id")
}

model document_templates {
  id               BigInt         @id @default(autoincrement())
  institution_id   BigInt
  document_type_id BigInt
  name             String         @db.VarChar(255)
  header_html      String?        @db.Text
  body_structure   String?        @db.Text
  footer_html      String?        @db.Text
  signature_block  String?        @db.Text
  is_default       Boolean?       @default(false)
  is_active        Boolean?       @default(true)
  created_at       DateTime?      @default(now()) @db.DateTime(0)
  updated_at       DateTime?      @default(now()) @db.DateTime(0)
  institutions     institutions   @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_templates_ibfk_1")
  document_types   document_types @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_templates_ibfk_2")
  documents        documents[]

  @@index([document_type_id], map: "document_type_id")
  @@index([institution_id], map: "institution_id")
}

model document_types {
  id                 BigInt               @id @default(autoincrement())
  name               String               @db.VarChar(100)
  code               String               @db.VarChar(20)
  description        String?              @db.Text
  is_active          Boolean?             @default(true)
  document_sequences document_sequences[]
  document_templates document_templates[]
  documents          documents[]
}

model document_versions {
  id             BigInt    @id @default(autoincrement())
  document_id    BigInt
  version_number Int
  content        String    @db.LongText
  edited_by      BigInt
  change_summary String?   @db.Text
  created_at     DateTime? @default(now()) @db.DateTime(0)
  documents      documents @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_versions_ibfk_1")
  users          users     @relation(fields: [edited_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "document_versions_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([edited_by], map: "edited_by")
}

model documents {
  id                   BigInt                 @id @default(autoincrement())
  institution_id       BigInt
  document_type_id     BigInt
  template_id          BigInt?
  created_by           BigInt
  number               Int
  year                 Int
  subject              String?                @db.VarChar(255)
  recipient_name       String?                @db.VarChar(255)
  recipient_email      String?                @db.VarChar(150)
  status               documents_status?      @default(draft)
  content              String?                @db.LongText
  pdf_url              String?                @db.VarChar(500)
  ai_prompt            String?                @db.Text
  ai_model             String?                @db.VarChar(100)
  generated_by_ai      Boolean?               @default(true)
  created_at           DateTime?              @default(now()) @db.DateTime(0)
  updated_at           DateTime?              @default(now()) @db.DateTime(0)
  document_approvals   document_approvals[]
  document_attachments document_attachments[]
  document_sends       document_sends[]
  document_versions    document_versions[]
  institutions         institutions           @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "documents_ibfk_1")
  document_types       document_types         @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "documents_ibfk_2")
  document_templates   document_templates?    @relation(fields: [template_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "documents_ibfk_3")
  users                users                  @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "documents_ibfk_4")

  @@unique([institution_id, document_type_id, number, year], map: "unique_document_number")
  @@index([created_by], map: "created_by")
  @@index([document_type_id], map: "document_type_id")
  @@index([template_id], map: "template_id")
}

model institutions {
  id                 BigInt               @id @default(autoincrement())
  name               String               @db.VarChar(255)
  cnpj               String?              @db.VarChar(20)
  address            String?              @db.VarChar(255)
  phone              String?              @db.VarChar(30)
  email              String?              @db.VarChar(150)
  logo_url           String?              @db.VarChar(500)
  responsible_name   String?              @db.VarChar(255)
  created_at         DateTime?            @default(now()) @db.DateTime(0)
  updated_at         DateTime?            @default(now()) @db.DateTime(0)
  audit_logs         audit_logs[]
  contact_groups     contact_groups[]
  contacts           contacts[]
  document_sequences document_sequences[]
  document_templates document_templates[]
  documents          documents[]
  system_settings    system_settings[]
  users              users[]
}

model profiles {
  id          BigInt  @id @default(autoincrement())
  name        String  @db.VarChar(100)
  description String? @db.Text
  users       users[]
}

model system_settings {
  id             BigInt       @id @default(autoincrement())
  institution_id BigInt
  setting_key    String       @db.VarChar(100)
  setting_value  String?      @db.Text
  created_at     DateTime?    @default(now()) @db.DateTime(0)
  updated_at     DateTime?    @default(now()) @db.DateTime(0)
  institutions   institutions @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "system_settings_ibfk_1")

  @@unique([institution_id, setting_key], map: "unique_setting")
}

model users {
  id                                                        BigInt                 @id @default(autoincrement())
  institution_id                                            BigInt
  profile_id                                                BigInt
  name                                                      String                 @db.VarChar(255)
  email                                                     String                 @unique(map: "email") @db.VarChar(150)
  password_hash                                             String                 @db.VarChar(255)
  position                                                  String?                @db.VarChar(150)
  phone                                                     String?                @db.VarChar(30)
  is_active                                                 Boolean?               @default(true)
  last_login_at                                             DateTime?              @db.DateTime(0)
  created_at                                                DateTime?              @default(now()) @db.DateTime(0)
  updated_at                                                DateTime?              @default(now()) @db.DateTime(0)
  audit_logs                                                audit_logs[]
  document_approvals_document_approvals_requested_byTousers document_approvals[]   @relation("document_approvals_requested_byTousers")
  document_approvals_document_approvals_approved_byTousers  document_approvals[]   @relation("document_approvals_approved_byTousers")
  document_attachments                                      document_attachments[]
  document_sends                                            document_sends[]
  document_versions                                         document_versions[]
  documents                                                 documents[]
  institutions                                              institutions           @relation(fields: [institution_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_ibfk_1")
  profiles                                                  profiles               @relation(fields: [profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_ibfk_2")

  @@index([institution_id], map: "institution_id")
  @@index([profile_id], map: "profile_id")
}

enum document_sends_channel {
  email
  whatsapp
  download
}

enum document_approvals_status {
  pending
  approved
  rejected
  correction_requested
}

enum document_sends_status {
  sent
  failed
  pending
}

enum documents_status {
  draft
  review
  pending_approval
  approved
  sent
  archived
  cancelled
}
